<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Customer Support Chatbot</title>
<style>
  body {
    background: linear-gradient(135deg, #1e293b, #0f172a);
    font-family: "Poppins", sans-serif;
    color: #fff;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .chat-container {
    width: 400px;
    background: #1e293b;
    border-radius: 16px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .chat-header {
    background: #0ea5e9;
    padding: 16px;
    text-align: center;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scrollbar-width: thin;
  }
  .bot, .user {
    max-width: 75%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 14px;
    line-height: 1.4;
  }
  .bot {
    background: #0c4a6e;
    align-self: flex-start;
    border-bottom-left-radius: 0;
  }
  .user {
    background: #10b981;
    align-self: flex-end;
    border-bottom-right-radius: 0;
  }
  .chat-footer {
    display: flex;
    padding: 10px;
    background: #0f172a;
  }
  .chat-footer input {
    flex: 1;
    padding: 10px;
    border: none;
    border-radius: 10px;
    outline: none;
    background: #1e293b;
    color: #fff;
  }
  .chat-footer button {
    background: #0ea5e9;
    border: none;
    color: white;
    font-weight: 600;
    margin-left: 10px;
    border-radius: 10px;
    padding: 10px 16px;
    cursor: pointer;
  }
  .typing {
    font-size: 12px;
    color: #94a3b8;
    margin-left: 6px;
  }
</style>
</head>
<body>
  <div class="chat-container">
    <div class="chat-header">💬 Smart Customer Support Bot</div>
    <div class="chat-body" id="chatBody">
      <div class="bot">Hello! 👋 I’m your customer assistant. How can I help you today?</div>
    </div>
    <div class="chat-footer">
      <input type="text" id="userInput" placeholder="Type your message..." />
      <button onclick="sendMessage()">Send</button>
    </div>
  </div>

<script>
const chatBody = document.getElementById("chatBody");
const userInput = document.getElementById("userInput");

function addMessage(text, sender) {
  const msg = document.createElement("div");
  msg.classList.add(sender);
  msg.innerText = text;
  chatBody.appendChild(msg);
  chatBody.scrollTop = chatBody.scrollHeight;
}

function botReply(message) {
  message = message.toLowerCase();

  if (message.includes("hello") || message.includes("hi")) {
    return "Hi there! 👋 How can I help you today?";
  } 
  else if (message.includes("order") || message.includes("track")) {
    return "Sure! Please provide your order ID to check the status 📦";
  } 
  else if (message.includes("refund")) {
    return "Our refund policy allows returns within 7 days of delivery. Would you like me to connect you to an agent?";
  } 
  else if (message.includes("product") || message.includes("details")) {
    return "We have a wide range of products! Could you specify which category you’re interested in?";
  } 
  else if (message.includes("delivery")) {
    return "Delivery usually takes 3-5 working days 🚚. Would you like me to check the delivery status?";
  } 
  else if (message.includes("thanks") || message.includes("thank")) {
    return "You're welcome! 😊 Happy to help.";
  } 
  else if (message.includes("bye")) {
    return "Goodbye! 👋 Have a great day!";
  } 
  else {
    return "I'm sorry, I didn’t understand that 🤔. Could you rephrase your question?";
  }
}

function sendMessage() {
  const msg = userInput.value.trim();
  if (msg === "") return;

  addMessage(msg, "user");
  userInput.value = "";

  // Simulate typing delay
  const typing = document.createElement("div");
  typing.classList.add("bot", "typing");
  typing.textContent = "Bot is typing...";
  chatBody.appendChild(typing);
  chatBody.scrollTop = chatBody.scrollHeight;

  setTimeout(() => {
    typing.remove();
    const reply = botReply(msg);
    addMessage(reply, "bot");
  }, 800);
}
</script>
</body>
</html>
