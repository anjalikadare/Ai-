<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Stock Market Trading Expert System</title>
<style>
  body {
    margin: 0;
    font-family: "Poppins", sans-serif;
    background: linear-gradient(135deg, #020617, #0f172a);
    color: #e2e8f0;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
  }

  .container {
    width: 500px;
    background: #1e293b;
    border-radius: 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.4);
    padding: 20px 30px;
  }

  h2 {
    text-align: center;
    color: #38bdf8;
    margin-bottom: 10px;
  }

  p {
    text-align: center;
    color: #94a3b8;
    font-size: 14px;
  }

  label {
    display: block;
    margin-top: 15px;
    color: #cbd5e1;
  }

  select, input {
    width: 100%;
    margin-top: 6px;
    padding: 10px;
    border-radius: 8px;
    border: none;
    outline: none;
    background: #334155;
    color: #fff;
  }

  button {
    width: 100%;
    margin-top: 20px;
    padding: 12px;
    border: none;
    border-radius: 10px;
    background: #0ea5e9;
    color: white;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
  }

  button:hover {
    background: #0284c7;
  }

  .result {
    margin-top: 20px;
    padding: 15px;
    border-radius: 10px;
    background: #0f172a;
    text-align: center;
    font-weight: bold;
    font-size: 16px;
  }

  .buy { color: #22c55e; }
  .sell { color: #ef4444; }
  .hold { color: #facc15; }

  footer {
    text-align: center;
    font-size: 12px;
    color: #64748b;
    margin-top: 15px;
  }
</style>
</head>
<body>

<div class="container">
  <h2>💹 AI Stock Trading Expert System</h2>
  <p>Get AI-driven Buy/Sell/Hold advice based on market indicators</p>

  <label>Market Trend:</label>
  <select id="trend">
    <option value="bullish">Bullish (rising market)</option>
    <option value="bearish">Bearish (falling market)</option>
    <option value="neutral">Neutral</option>
  </select>

  <label>Stock Price Movement:</label>
  <select id="priceMovement">
    <option value="increasing">Increasing</option>
    <option value="decreasing">Decreasing</option>
    <option value="stable">Stable</option>
  </select>

  <label>RSI (Relative Strength Index):</label>
  <select id="rsi">
    <option value="low">Low (oversold)</option>
    <option value="medium">Medium (balanced)</option>
    <option value="high">High (overbought)</option>
  </select>

  <label>Trading Volume:</label>
  <select id="volume">
    <option value="high">High</option>
    <option value="average">Average</option>
    <option value="low">Low</option>
  </select>

  <label>News Sentiment:</label>
  <select id="sentiment">
    <option value="positive">Positive</option>
    <option value="neutral">Neutral</option>
    <option value="negative">Negative</option>
  </select>

  <button onclick="analyze()">Analyze & Get Recommendation</button>

  <div class="result" id="result">Your trading recommendation will appear here.</div>

  <footer>Developed by Mrunali Manik Mane | AI & DS Major Project</footer>
</div>

<script>
function analyze() {
  const trend = document.getElementById("trend").value;
  const price = document.getElementById("priceMovement").value;
  const rsi = document.getElementById("rsi").value;
  const volume = document.getElementById("volume").value;
  const sentiment = document.getElementById("sentiment").value;

  let decision = "";
  let reason = "";

  // Rule-based expert logic
  if (trend === "bullish" && price === "increasing" && rsi === "medium" && sentiment === "positive") {
    decision = "BUY";
    reason = "Strong uptrend with positive sentiment and balanced RSI.";
  } 
  else if (trend === "bearish" && (price === "decreasing" || sentiment === "negative")) {
    decision = "SELL";
    reason = "Bearish market with negative sentiment.";
  } 
  else if (rsi === "high" && price === "increasing") {
    decision = "SELL";
    reason = "Stock appears overbought. Profit booking suggested.";
  } 
  else if (rsi === "low" && sentiment === "positive") {
    decision = "BUY";
    reason = "Stock is oversold but sentiment improving.";
  } 
  else if (trend === "neutral" || sentiment === "neutral") {
    decision = "HOLD";
    reason = "Market uncertainty detected. Wait for clearer signals.";
  } 
  else {
    decision = "HOLD";
    reason = "Mixed indicators detected.";
  }

  const result = document.getElementById("result");
  result.className = "result"; // Reset
  if (decision === "BUY") result.classList.add("buy");
  if (decision === "SELL") result.classList.add("sell");
  if (decision === "HOLD") result.classList.add("hold");

  result.innerHTML = `<strong>Recommendation: ${decision}</strong><br><br>Reason: ${reason}`;
}
</script>

</body>
</html>
